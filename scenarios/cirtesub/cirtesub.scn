		<actuator name="Thruster_up_left" type="thruster">
			<origin rpy="0.0 1.5708 0.0" xyz="0.304457 0.02257 0.168299"/>
			<specs max_setpoint="${3278.0/60.0*2.0*pi}" inverted_setpoint="true" normalized_setpoint="true"/>
			<propeller diameter="0.07" right="true">
				<mesh filename="cirtesub/Propeller.obj" scale="1.0"/>
				<material name="Neutral"/>
				<look name="propeller"/>
			</propeller>
			<link name="Vehicle"/>
			<rotor_dynamics type="mechanical_pi">
				<rotor_inertia value="0.05"/>
				<kp value="0.8"/>
				<ki value="0.2"/>
				<ilimit value="2.0"/>
			</rotor_dynamics>
			<thrust_model type="fluid_dynamics">
				<thrust_coeff forward="0.52" reverse="0.48"/>
				<torque_coeff value="0.001"/>
			</thrust_model>
		</actuator>

